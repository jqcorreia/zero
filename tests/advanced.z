import "std/c"

struct Point {
    coords: Coords
}

struct Coords {
    x: f64
    y: f64
}

struct Triangle {
    points: [3]Point
}

fn main() {
    p := Point { 
        coords = Coords{
            x= 1.0, 
            y= 2.0 }
        }

    a: [3]u32 = [1,3,4]

    t := Triangle {
        points = [
            Point { coords = Coords{x= 7.25, y= 42.1337 }},
            Point { coords = Coords{x= 1.0, y= 0.0 }},
            Point { coords = Coords{x= 0.0, y= 1.0 }}
        ]
    }

    printf("Point: (%.2f, %.2f)\n", p.coords.x, p.coords.y)
    printf("Triangle first point: (%.2f, %.2f)\n", t.points[0].coords.x, t.points[0].coords.y)
}
