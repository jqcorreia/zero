import "std/c"

struct Point {
    x: i32
    y: i32
}

fn main() {
    // Numeric zero init
    i: i32
    f: f64

    // String zero init
    msg: cstr

    // Array zero init
    arr: [4]i32

    // Struct zero init
    p: Point

    printf("i=%d f=%f msg=%s\n", i, f, msg)
    printf("arr=[%d %d %d %d]\n", arr[0], arr[1], arr[2], arr[3])
    printf("p={x=%d y=%d}\n", p.x, p.y)
}
