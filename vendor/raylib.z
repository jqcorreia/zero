    fn LoadMaterialDefault() -> Material
    fn IsMaterialValid(material: Material) -> bool
    fn UnloadMaterial(material: Material)
    fn SetMaterialTexture(material: &Material, mapType: i32, texture: Texture)
    fn SetModelMeshMaterial(model: &Model, meshId: i32, materialId: i32)
    fn LoadModelAnimations(fileName: str, animCount: &i32) -> &ModelAnimation
    fn UpdateModelAnimation(model: Model, anim: ModelAnimation, frame: i32)
    fn UpdateModelAnimationEx(model: Model, animA: ModelAnimation, frameA: i32, animB: ModelAnimation, frameB: i32, blend: f32)
    fn UnloadModelAnimations(animations: &ModelAnimation, animCount: i32)
    fn IsModelAnimationValid(model: Model, anim: ModelAnimation) -> bool
    fn CheckCollisionSpheres(center1: Vector3, radius1: f32, center2: Vector3, radius2: f32) -> bool
    fn CheckCollisionBoxes(box1: BoundingBox, box2: BoundingBox) -> bool
    fn CheckCollisionBoxSphere(box: BoundingBox, center: Vector3, radius: f32) -> bool
    fn GetRayCollisionSphere(ray: Ray, center: Vector3, radius: f32) -> RayCollision
    fn GetRayCollisionBox(ray: Ray, box: BoundingBox) -> RayCollision
    fn GetRayCollisionMesh(ray: Ray, mesh: Mesh, transform: Matrix) -> RayCollision
    fn GetRayCollisionTriangle(ray: Ray, p1: Vector3, p2: Vector3, p3: Vector3) -> RayCollision
    fn GetRayCollisionQuad(ray: Ray, p1: Vector3, p2: Vector3, p3: Vector3, p4: Vector3) -> RayCollision
}

