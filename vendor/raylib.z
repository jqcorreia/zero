// === TEXT ===

external "raylib" {
    fn GetFontDefault() -> Font
    fn LoadFont(fileName: str) -> Font
    fn LoadFontEx(fileName: str, fontSize: i32, codepoints: &i32, codepointCount: i32) -> Font
    fn LoadFontFromImage(image: Image, key: Color, firstChar: i32) -> Font
    fn LoadFontFromMemory(fileType: str, fileData: &u8, dataSize: i32, fontSize: i32, codepoints: &i32, codepointCount: i32) -> Font
    fn IsFontValid(font: Font) -> bool
    fn LoadFontData(fileData: &u8, dataSize: i32, fontSize: i32, codepoints: &i32, codepointCount: i32, type: i32, glyphCount: &i32) -> &GlyphInfo
    fn GenImageFontAtlas(glyphs: &GlyphInfo, glyphRecs: str, glyphCount: i32, fontSize: i32, padding: i32, packMethod: i32) -> Image
    fn UnloadFontData(glyphs: &GlyphInfo, glyphCount: i32)
    fn UnloadFont(font: Font)
    fn ExportFontAsCode(font: Font, fileName: str) -> bool
    fn DrawFPS(posX: i32, posY: i32)
    fn DrawText(text: str, posX: i32, posY: i32, fontSize: i32, color: Color)
    fn DrawTextEx(font: Font, text: str, position: Vector2, fontSize: f32, spacing: f32, tint: Color)
    fn DrawTextPro(font: Font, text: str, position: Vector2, origin: Vector2, rotation: f32, fontSize: f32, spacing: f32, tint: Color)
    fn DrawTextCodepoint(font: Font, codepoint: i32, position: Vector2, fontSize: f32, tint: Color)
    fn DrawTextCodepoints(font: Font, codepoints: &i32, codepointCount: i32, position: Vector2, fontSize: f32, spacing: f32, tint: Color)
    fn SetTextLineSpacing(spacing: i32)
    fn MeasureText(text: str, fontSize: i32) -> i32
    fn MeasureTextEx(font: Font, text: str, fontSize: f32, spacing: f32) -> Vector2
    fn MeasureTextCodepoints(font: Font, codepoints: &i32, length: i32, fontSize: f32, spacing: f32) -> Vector2
    fn GetGlyphIndex(font: Font, codepoint: i32) -> i32
    fn GetGlyphInfo(font: Font, codepoint: i32) -> GlyphInfo
    fn GetGlyphAtlasRec(font: Font, codepoint: i32) -> Rectangle
    fn LoadUTF8(codepoints: &i32, length: i32) -> str
    fn UnloadUTF8(text: str)
    fn LoadCodepoints(text: str, count: &i32) -> &i32
    fn UnloadCodepoints(codepoints: &i32)
    fn GetCodepointCount(text: str) -> i32
    fn GetCodepoint(text: str, codepointSize: &i32) -> i32
    fn GetCodepointNext(text: str, codepointSize: &i32) -> i32
    fn GetCodepointPrevious(text: str, codepointSize: &i32) -> i32
    fn CodepointToUTF8(codepoint: i32, utf8Size: &i32) -> str
    // fn LoadTextLines(text: str, count: &i32) -> str   // char** not supported
    // fn UnloadTextLines(text: str, lineCount: i32)     // char** not supported
    fn TextCopy(dst: str, src: str) -> i32
    fn TextIsEqual(text1: str, text2: str) -> bool
    fn TextLength(text: str) -> u32
    fn TextFormat(text: str, ...) -> str
    fn TextSubtext(text: str, position: i32, length: i32) -> str
    fn TextRemoveSpaces(text: str) -> str
    fn GetTextBetween(text: str, begin: str, end: str) -> str
    fn TextReplace(text: str, search: str, replacement: str) -> str
    fn TextReplaceBetween(text: str, begin: str, end: str, replacement: str) -> str
    fn TextInsert(text: str, insert: str, position: i32) -> str
    // fn TextJoin(textList: str, count: i32, delimiter: str) -> str  // char** not supported
    // fn TextSplit(text: str, delimiter: u8, count: &i32) -> str     // char** not supported
    fn TextAppend(text: str, append: str, position: &i32)
    fn TextFindIndex(text: str, search: str) -> i32
    fn TextToUpper(text: str) -> str
    fn TextToLower(text: str) -> str
    fn TextToPascal(text: str) -> str
    fn TextToSnake(text: str) -> str
    fn TextToCamel(text: str) -> str
    fn TextToInteger(text: str) -> i32
    fn TextToFloat(text: str) -> f32
}

